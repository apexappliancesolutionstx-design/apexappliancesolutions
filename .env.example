# ── Lead email delivery (Resend) ──────────────────────────────────────────
# Copy this file to ".env" and fill in real values. Never commit ".env".
#
# 1. Create a free account at https://resend.com
# 2. Add & verify your sending domain (e.g. apexappliancesolutions.com)
# 3. Create an API key and paste it below.

# API key from the Resend dashboard (starts with "re_")
RESEND_API_KEY=

# Where new leads are emailed (your inbox)
LEAD_NOTIFY_TO=owner@apexappliancesolutions.com

# Verified "from" address. Until your domain is verified you can use Resend's
# sandbox sender: "Apex Leads <onboarding@resend.dev>"
LEAD_NOTIFY_FROM=Apex Leads <leads@apexappliancesolutions.com>
